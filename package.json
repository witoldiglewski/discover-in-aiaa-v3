{
  "name": "discover-in-aiaa",
  "version": "1.0.0",
  "private": true,
  "description": "Discover automation opportunities - Multi-version prototype",
  "scripts": {
    "dev:v1": "cd v1 && npm run dev",
    "dev:v2": "cd v2 && npm run dev",
    "dev:both": "npm-run-all --parallel dev:v1 dev:v2",
    "build:v1": "cd v1 && npm run build",
    "build:v2": "cd v2 && npm run build",
    "build:both": "npm-run-all build:v1 build:v2",
    "install:v1": "cd v1 && npm install",
    "install:v2": "cd v2 && npm install",
    "install:all": "npm-run-all install:v1 install:v2",
    "test:v1": "cd v1 && npm run test",
    "test:v2": "cd v2 && npm run test"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
